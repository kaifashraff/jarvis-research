        "# 🔬 Advanced Analytics Setup\n",
        "print(\"🔬 Advanced Analytics - JARVIS v2.0\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "!pip install -q textblob vaderSentiment prophet\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from textblob import TextBlob\n",
        "from vaderSentiment.vaderSentiment import SentimentIntensityAnalyzer\n",
        "from prophet import Prophet\n",
        "import json\n",
        "\n",
        "print(\"✅ Advanced analytics environment ready!\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# 📊 Demand Forecasting with Prophet\n",
        "print(\"📈 Building demand forecasting model...\")\n",
        "\n",
        "# Simulated historical data\n",
        "dates = pd.date_range(start='2024-01-01', end='2026-03-18', freq='D')\n",
        "np.random.seed(42)\n",
        "\n",
        "# Wedding season patterns (Oct-Feb peak)\n",
        "seasonal_pattern = np.sin(2 * np.pi * (dates.dayofyear - 100) / 365) * 0.5 + 0.5\n",
        "demand = 100 + 50 * seasonal_pattern + np.random.randn(len(dates)) * 10\n",
        "\n",
        "df_demand = pd.DataFrame({\n",
        "    'ds': dates,\n",
        "    'y': demand\n",
        "})\n",
        "\n",
        "# Train Prophet model\n",
        "model = Prophet(\n",
        "    yearly_seasonality=True,\n",
        "    weekly_seasonality=True,\n",
        "    daily_seasonality=False\n",
        ")\n",
        "model.fit(df_demand)\n",
        "\n",
        "# Future predictions\n",
        "future = model.make_future_dataframe(periods=90)\n",
        "forecast = model.predict(future)\n",
        "\n",
        "# Visualize\n",
        "fig, axes = plt.subplots(2, 1, figsize=(15, 10))\n",
        "\n",
        "# Historical + Forecast\n",
        "axes[0].plot(df_demand['ds'], df_demand['y'], label='Historical', color='cyan', alpha=0.7)\n",
        "axes[0].plot(forecast['ds'], forecast['yhat'], label='Forecast', color='lime', linewidth=2)\n",
        "axes[0].fill_between(forecast['ds'], forecast['yhat_lower'], forecast['yhat_upper'], \n",
        "                     alpha=0.2, color='lime', label='Confidence Interval')\n",
        "axes[0].set_title('📊 Demand Forecast (90 days)', fontsize=14, color='lime')\n",
        "axes[0].set_xlabel('Date')\n",
        "axes[0].set_ylabel('Demand Index')\n",
        "axes[0].legend()\n",
        "axes[0].grid(True, alpha=0.3)\n",
        "\n",
        "# Seasonal components\n",
        "seasonal = forecast[['ds', 'yearly', 'weekly']].tail(90)\n",
        "axes[1].plot(seasonal['ds'], seasonal['yearly'], label='Yearly Seasonality', color='gold')\n",
        "axes[1].plot(seasonal['ds'], seasonal['weekly'], label='Weekly Seasonality', color='magenta')\n",
        "axes[1].set_title('🌍 Seasonal Patterns", fontsize=14, color='gold')\n",
        "axes[1].set_xlabel('Date')\n",
        "axes[1].set_ylabel('Seasonal Effect')\n",
        "axes[1].legend()\n",
        "axes[1].grid(True, alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Forecast insights\n",
        "peak_date = forecast.loc[forecast['yhat'].idxmax(), 'ds']\n",
        "peak_demand = forecast['yhat'].max()\n",
        "\n",
        "print(f\"\\n📈 Demand Forecast Insights:\")\n",
        "print(f\"Peak Demand Date: {peak_date.strftime('%Y-%m-%d')}\")\n",
        "print(f\"Peak Demand Value: {peak_demand:.1f}\")\n",
        "print(f\"Average Demand: {forecast['yhat'].mean():.1f}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# 💬 Sentiment Analysis for Customer Feedback\n",
        "print(\"💬 Analyzing customer sentiment...\")\n",
        "\n",
        "# Sample customer feedback\n",
        "feedback_samples = [\n",
        "    \"The zari work quality is exceptional! Best in the market.\",\n",
        "    \"Delivery was delayed by 2 weeks. Very disappointing.\",\n",
        "    \"Beautiful embroidery, but prices are quite high.\",\n",
        "    \"Outstanding craftsmanship! Will definitely order again.\",\n",
        "    \"Average quality, seen better work from other vendors.\",\n",
        "    \"The designs are unique and the finishing is perfect.\",\n",
        "    \"Customer service needs improvement.\",\n",
        "    \"Worth every penny! The intricate details are amazing.\",\n",
        "    \"Not satisfied with the color matching.\",\n",
        "    \"Highly recommend! Professional work and timely delivery.\"\n",
        "]\n",
        "\n",
        "# Analyze sentiment\n",
        "analyzer = SentimentIntensityAnalyzer()\n",
        "sentiment_results = []\n",
        "\n",
        "for feedback in feedback_samples:\n",
        "    scores = analyzer.polarity_scores(feedback)\n",
        "    sentiment = 'Positive' if scores['compound'] > 0.05 else 'Negative' if scores['compound'] < -0.05 else 'Neutral'\n",
        "    sentiment_results.append({\n",
        "        'Feedback': feedback,\n",
        "        'Positive': scores['pos'],\n",
        "        'Negative': scores['neg'],\n",
        "        'Neutral': scores['neu'],\n",
        "        'Compound': scores['compound'],\n",
        "        'Sentiment': sentiment\n",
        "    })\n",
        "\n",
        "df_sentiment = pd.DataFrame(sentiment_results)\n",
        "\n",
        "# Visualize sentiment\n",
        "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
        "\n",
        "# Sentiment distribution\n",
        "sentiment_counts = df_sentiment['Sentiment'].value_counts()\n",
        "axes[0].pie(sentiment_counts.values, labels=sentiment_counts.index, autopct='%1.1f%%',\n",
        "           colors=['lime', 'red', 'gray'], startangle=90)\n",
        "axes[0].set_title('💬 Sentiment Distribution', fontsize=14, color='white')\n",
        "\n",
        "# Compound scores\n",
        "axes[1].barh(range(len(df_sentiment)), df_sentiment['Compound'], \n",
        "            color=['lime' if x > 0 else 'red' for x in df_sentiment['Compound']])\n",
        "axes[1].set_title('📊 Sentiment Scores", fontsize=14, color='cyan')\n",
        "axes[1].set_xlabel('Compound Score')\n",
        "axes[1].set_ylabel('Feedback Index')\n",
        "axes[1].grid(True, alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Insights\n",
        "print(\"\\n💬 Sentiment Analysis Insights:\")\n",
        "print(f\"Total Feedback Analyzed: {len(df_sentiment)}\")\n",
        "print(f\"Positive: {len(df_sentiment[df_sentiment['Sentiment'] == 'Positive'])}\")\n",
        "print(f\"Negative: {len(df_sentiment[df_sentiment['Sentiment'] == 'Negative'])}\")\n",
        "print(f\"Neutral: {len(df_sentiment[df_sentiment['Sentiment'] == 'Neutral'])}\")\n",
        "print(f\"Average Compound Score: {df_sentiment['Compound'].mean():.3f}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
